<!DOCTYPE html>
<html lang="{{ .lang }}">
<head>
    <title>{{ .title }}</title>
    <meta name="description" content="inceptiondb">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="/css/style.css" rel="stylesheet">
    <link href="/css/blue.css" rel="stylesheet">
    <script defer src="https://umami.hola.cloud/script.js" data-website-id="cbcb870c-e9a8-460a-8b38-ab2fa77a4cc2"></script>
</head>
<body url="{{ .url }}">
<!-- inceptiondb en src/50_inceptiondb/inceptiondb_en.md  -->
<div class="top-frame">
    <div class="top">
        <a href="/" class="logo"></a>
        <div class="main-menu">
            <div class="dropdown">
                <button class="link dropdown-toggle" type="button">
                    Products
                    <span class="dropdown-icon" aria-hidden="true">▾</span>
                </button>
                <div class="dropdown-menu" role="menu">
                    <a class="dropdown-item" href="https://flowtest.io" target="_blank" rel="noopener">
                        <span class="item-title">Flowtest.io</span>
                        <span class="item-description">Automated load testing from the hola.cloud ecosystem.</span>
                    </a>
                    <a class="dropdown-item" href="https://inceptiondb.hola.cloud" target="_blank" rel="noopener">
                        <span class="item-title">InceptioDB</span>
                        <span class="item-description">Fully managed database service within the hola.cloud ecosystem.</span>
                    </a>
                    <a class="dropdown-item" href="https://console.hola.cloud" target="_blank" rel="noopener">
                        <span class="item-title">Public Cloud</span>
                        <span class="item-description">Deploy and manage your workloads on the hola.cloud public platform.</span>
                    </a>
                    <a class="dropdown-item" href="https://gopress.org" target="_blank" rel="noopener">
                        <span class="item-title">GoPress <span class="item-tag">Open Source</span></span>
                        <span class="item-description">Open-source CMS built for the hola.cloud ecosystem.</span>
                    </a>
                </div>
            </div>
            {{/*link "pricing"*/}}
            {{ link "docs" }}
            {{/*  {{ link "blog" }}*/}}
            <a class="link button-console" href="https://console.hola.cloud/">Console</a>
        </div>
        <div class="right">
            <a id="login-button" class="button button-noborder" href="https://console.hola.cloud/">Log In</a>
            <a class="button button-action" href="https://console.hola.cloud/">Start now</a>
        </div>
    </div>
</div>
<div class="languages-frame">
    {{ .langMenu }}
</div>
<div class="tree">
{{ .versionMenu }}
{{ if isUnder "docs" }}
    {{ tree "docs" }}
{{ end }}
{{ if isUnder "inceptiondb" }}
    {{ tree "inceptiondb" }}
{{ end }}
</div>
<div class="content">
    {{ .breadcrumb }}
    <div class="index">{{ .index }}</div>
    <div class="document">
    {{ .content }}
    </div>
</div>
<div id="comments-section">
    <h2>{{ if eq .lang "es" }}Comentarios{{ else if eq .lang "zh" }}评论{{ else }}Comments{{ end }}</h2>
    <div id="comments-list"></div>
    <form id="comment-form" class="comment-form">
        <h3>{{ if eq .lang "es" }}Deja un comentario{{ else if eq .lang "zh" }}发表评论{{ else }}Leave a comment{{ end }}</h3>
        <div class="comment-form-row">
            <input type="text" name="author" id="comment-author" placeholder="{{ if eq .lang "es" }}Tu nombre{{ else if eq .lang "zh" }}您的姓名{{ else }}Your name{{ end }}" required>
            <input type="email" name="email" id="comment-email" placeholder="{{ if eq .lang "es" }}Tu email (opcional){{ else if eq .lang "zh" }}邮箱（选填）{{ else }}Your email (optional){{ end }}">
        </div>
        <textarea name="content" id="comment-content" placeholder="{{ if eq .lang "es" }}Escribe un comentario...{{ else if eq .lang "zh" }}写评论...{{ else }}Write a comment...{{ end }}" required></textarea>
        <button type="submit" id="comment-submit">{{ if eq .lang "es" }}Enviar{{ else if eq .lang "zh" }}提交{{ else }}Submit{{ end }}</button>
        <p id="comment-status" class="comment-status"></p>
    </form>
</div>
<style>
#comments-section {
    max-width: 800px;
    margin: 3rem auto;
    padding: 0 1rem;
}
#comments-section h2 {
    border-bottom: 1px solid #e2e8f0;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
}
.comment {
    padding: 1rem;
    margin-bottom: 1rem;
    background: #f8fafc;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
}
.comment-author {
    font-weight: 600;
    color: #1e293b;
}
.comment-date {
    font-size: 0.85em;
    color: #64748b;
    margin-left: 0.5rem;
}
.comment-content {
    margin-top: 0.5rem;
    line-height: 1.5;
    color: #334155;
}
.comment-form {
    margin-top: 2rem;
    padding: 1.5rem;
    background: #f1f5f9;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
}
.comment-form h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.1rem;
}
.comment-form-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.75rem;
}
.comment-form-row input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid #cbd5e1;
    border-radius: 4px;
    font-size: 0.95rem;
}
#comment-content {
    width: 100%;
    min-height: 100px;
    padding: 0.5rem 0.75rem;
    border: 1px solid #cbd5e1;
    border-radius: 4px;
    font-size: 0.95rem;
    font-family: inherit;
    box-sizing: border-box;
    resize: vertical;
    margin-bottom: 0.75rem;
}
#comment-submit {
    padding: 0.5rem 1.5rem;
    background: #3b82f6;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 0.95rem;
    cursor: pointer;
}
#comment-submit:hover {
    background: #2563eb;
}
#comment-submit:disabled {
    background: #94a3b8;
    cursor: not-allowed;
}
.comment-status {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
}
.comment-status.error {
    color: #dc2626;
}
.comment-status.success {
    color: #16a34a;
}
.comments-empty {
    color: #64748b;
    font-style: italic;
}
</style>
<script>
(function() {
    function getPageID() {
        var el = document.querySelector('[data-page-id]');
        if (el) return el.getAttribute('data-page-id');
        var url = window.location.pathname || '/';
        var lang = document.documentElement.lang || 'en';
        return url.replace(/\/$/, '') + '|' + lang;
    }
    var pageID = getPageID();
    var list = document.getElementById('comments-list');
    var form = document.getElementById('comment-form');
    var authorInput = document.getElementById('comment-author');
    var emailInput = document.getElementById('comment-email');
    var contentInput = document.getElementById('comment-content');
    var submitBtn = document.getElementById('comment-submit');
    var statusEl = document.getElementById('comment-status');
    function loadComments() {
        fetch('/api/comments?page_id=' + encodeURIComponent(pageID))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.comments || data.comments.length === 0) {
                    list.innerHTML = '<p class="comments-empty">' + getText('noComments') + '</p>';
                    return;
                }
                var html = '';
                data.comments.forEach(function(c) {
                    var date = new Date(c.created_at).toLocaleDateString();
                    html += '<div class="comment">';
                    html += '<span class="comment-author">' + escapeHTML(c.author) + '</span>';
                    html += '<span class="comment-date">' + date + '</span>';
                    html += '<div class="comment-content">' + escapeHTML(c.content) + '</div>';
                    html += '</div>';
                });
                list.innerHTML = html;
            })
            .catch(function() {
                list.innerHTML = '<p class="comment-status error">' + getText('loadError') + '</p>';
            });
    }
    function getText(key) {
        var lang = document.documentElement.lang;
        var texts = {
            es: { noComments: 'No hay comentarios aún. Sé el primero en comentar.', loadError: 'Error al cargar comentarios.', sending: 'Enviando...', success: 'Comentario enviado con éxito.', error: 'Error al enviar el comentario.', submit: 'Enviar' },
            zh: { noComments: '还没有评论。成为第一个评论者。', loadError: '加载评论时出错。', sending: '发送中...', success: '评论发送成功。', error: '发送评论时出错。', submit: '提交' },
            en: { noComments: 'No comments yet. Be the first to comment.', loadError: 'Error loading comments.', sending: 'Sending...', success: 'Comment submitted successfully.', error: 'Error submitting comment.', submit: 'Submit' }
        };
        return (texts[lang] || texts['en'])[key];
    }
    function escapeHTML(str) {
        var d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
    }
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        submitBtn.disabled = true;
        submitBtn.textContent = getText('sending');
        statusEl.textContent = '';
        statusEl.className = 'comment-status';
        fetch('/api/comments', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                page_id: pageID,
                author: authorInput.value.trim(),
                email: emailInput.value.trim(),
                content: contentInput.value.trim()
            })
        })
        .then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function() {
            statusEl.textContent = getText('success');
            statusEl.className = 'comment-status success';
            authorInput.value = '';
            emailInput.value = '';
            contentInput.value = '';
            loadComments();
        })
        .catch(function() {
            statusEl.textContent = getText('error');
            statusEl.className = 'comment-status error';
        })
        .finally(function() {
            submitBtn.disabled = false;
            submitBtn.textContent = getText('submit');
        });
    });
    loadComments();
})();
</script>
