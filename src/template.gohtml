                <ul>
                    <li><a href="mailto:contact@hola.cloud">contact@hola.cloud</a></li>
                    <li><a href="tel:+34910000000">+34 910 000 000</a></li>
                    <li><a href="https://www.linkedin.com/company/hola-cloud" target="_blank" rel="noopener">LinkedIn</a></li>
